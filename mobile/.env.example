# Copy this file to mobile/.env and fill in the real values.
# Anything prefixed with EXPO_PUBLIC_ is readable in the app via process.env.

# Your Supabase project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# The ANON / public key (Supabase Dashboard > Project Settings > API > "anon public")
# This is safe to ship in a mobile app. Do NOT use the service_role key here.
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Your live backend base URL (no trailing slash)
EXPO_PUBLIC_API_URL=https://landlordrentmanagement.onrender.com
