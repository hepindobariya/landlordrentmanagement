# Server
# Render sets PORT automatically. Locally, defaults to 3000 if unset.
PORT=3000
NODE_ENV=development

# Supabase
# Found in: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — SERVER-SIDE ONLY. Never expose to the mobile app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anon key — optional for now, used later to verify end-user JWTs.
SUPABASE_ANON_KEY=your-anon-key

# EAS Build webhook secret — used to verify incoming EAS webhook signatures.
# Must match the secret you set when creating the webhook (eas webhook:create).
EAS_WEBHOOK_SECRET=your-eas-webhook-secret
